# Shared
NODE_ENV=development

# Backend
PORT=5001
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>/<database>?retryWrites=true&w=majority
JWT_ACCESS_SECRET=replace-with-a-long-random-access-secret
JWT_REFRESH_SECRET=replace-with-a-long-random-refresh-secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
CLIENT_URL=http://localhost:3000
COOKIE_DOMAIN=localhost

# Google OAuth
GOOGLE_CLIENT_ID=

# Twilio OTP
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_VERIFY_SERVICE_SID=

# Email
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
MAIL_FROM="M/S Manikyam Agriculture Hardware <no-reply@manikyam.local>"

# OpenAI AI Assistant
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:5001/api
NEXT_PUBLIC_SHOP_PHONE=+919999999999
NEXT_PUBLIC_WHATSAPP_NUMBER=919999999999
NEXT_PUBLIC_GOOGLE_MAP_EMBED_URL=https://www.google.com/maps?q=hardware%20electrical%20cement%20shop%20India&output=embed
